# Kotaeba environment configuration
#
# Required:
# - None strictly required: the app and server have defaults.
# - The entries below are the recommended baseline to define explicitly.

# ------------------------------------------------------------------------------
# Recommended baseline
# ------------------------------------------------------------------------------
STT_MODEL=mlx-community/Qwen3-ASR-0.6B-8bit
STT_HOST=127.0.0.1
STT_PORT=8000
LANGUAGE=en

# ------------------------------------------------------------------------------
# Optional audio tuning
# ------------------------------------------------------------------------------
AUDIO__RATE=16000
AUDIO__CHANNELS=1
AUDIO__CHUNK_SIZE=1024
AUDIO__FORMAT=paInt16

# ------------------------------------------------------------------------------
# Optional VAD tuning
# ------------------------------------------------------------------------------
VAD__ENABLED=true
VAD__FRAME_DURATION_MS=30
VAD__VAD_MODE=3
VAD__SILENCE_LIMIT_MS=1000
VAD__PRE_SPEECH_MS=500

# ------------------------------------------------------------------------------
# Optional paths and logging
# ------------------------------------------------------------------------------
LOG_FILE=logs/kotaeba.log
LOG_ROTATION=10 MB
LOG_COMPRESSION=zip
RECORDINGS_DIR=recordings

# ------------------------------------------------------------------------------
# Optional sensitive values
# Keep these out of git and store securely in app Keychain settings when possible.
# ------------------------------------------------------------------------------
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=
